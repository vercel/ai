    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "ai": "7.0.0-beta.96",
    "autoprefixer": "^10.4.20",
    "bits-ui": "^1.3.9",
    "clsx": "^2.1.1",
    "svelte": "^5.31.0",
    "svelte-check": "^4.0.0",
    "tailwind-merge": "^3.0.2",
    "tailwind-variants": "^1.0.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
