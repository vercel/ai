# =============================================================================
# AI SDK — Provider Environment Variables
# =============================================================================
# This file lists every environment variable read by the provider packages in
# `packages/`. Copy to `.env` and fill in only the variables for providers you
# actually use — none of them are required globally.
# =============================================================================


# -----------------------------------------------------------------------------
# Alibaba (@ai-sdk/alibaba)
# -----------------------------------------------------------------------------
ALIBABA_API_KEY=""


# -----------------------------------------------------------------------------
# Amazon Bedrock (@ai-sdk/amazon-bedrock)
# -----------------------------------------------------------------------------
# Use AWS_BEARER_TOKEN_BEDROCK for API-key auth, or the access-key trio below
# for SigV4. AWS_SESSION_TOKEN is only needed for temporary credentials.
AWS_BEARER_TOKEN_BEDROCK=""
AWS_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_SESSION_TOKEN=""


# -----------------------------------------------------------------------------
# Anthropic (@ai-sdk/anthropic)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=""
# Override the default API base URL (optional).
ANTHROPIC_BASE_URL=""


# -----------------------------------------------------------------------------
# AssemblyAI (@ai-sdk/assemblyai)
# -----------------------------------------------------------------------------
ASSEMBLYAI_API_KEY=""


# -----------------------------------------------------------------------------
# Azure OpenAI (@ai-sdk/azure)
# -----------------------------------------------------------------------------
AZURE_API_KEY=""
AZURE_RESOURCE_NAME=""


# -----------------------------------------------------------------------------
# Baseten (@ai-sdk/baseten)
# -----------------------------------------------------------------------------
BASETEN_API_KEY=""


# -----------------------------------------------------------------------------
# Black Forest Labs (@ai-sdk/black-forest-labs)
# -----------------------------------------------------------------------------
BFL_API_KEY=""


# -----------------------------------------------------------------------------
# ByteDance / Volcengine Ark (@ai-sdk/bytedance)
# -----------------------------------------------------------------------------
ARK_API_KEY=""


# -----------------------------------------------------------------------------
# Cerebras (@ai-sdk/cerebras)
# -----------------------------------------------------------------------------
CEREBRAS_API_KEY=""


# -----------------------------------------------------------------------------
# Cohere (@ai-sdk/cohere)
# -----------------------------------------------------------------------------
COHERE_API_KEY=""


# -----------------------------------------------------------------------------
# Deepgram (@ai-sdk/deepgram)
# -----------------------------------------------------------------------------
DEEPGRAM_API_KEY=""


# -----------------------------------------------------------------------------
# DeepInfra (@ai-sdk/deepinfra)
# -----------------------------------------------------------------------------
DEEPINFRA_API_KEY=""


# -----------------------------------------------------------------------------
# DeepSeek (@ai-sdk/deepseek)
# -----------------------------------------------------------------------------
DEEPSEEK_API_KEY=""


# -----------------------------------------------------------------------------
# ElevenLabs (@ai-sdk/elevenlabs)
# -----------------------------------------------------------------------------
ELEVENLABS_API_KEY=""


# -----------------------------------------------------------------------------
# fal.ai (@ai-sdk/fal)
# -----------------------------------------------------------------------------
# FAL_API_KEY is preferred; FAL_KEY is used as a fallback for compatibility.
FAL_API_KEY=""
FAL_KEY=""


# -----------------------------------------------------------------------------
# Fireworks (@ai-sdk/fireworks)
# -----------------------------------------------------------------------------
FIREWORKS_API_KEY=""


# -----------------------------------------------------------------------------
# Vercel AI Gateway (@ai-sdk/gateway)
# -----------------------------------------------------------------------------
# AI_GATEWAY_API_KEY is used outside Vercel deployments. Inside a Vercel
# deployment, authentication falls back to VERCEL_OIDC_TOKEN automatically.
# The remaining VERCEL_* values are auto-populated on Vercel and are only
# needed locally if you want to mirror that environment.
AI_GATEWAY_API_KEY=""
VERCEL_OIDC_TOKEN=""
VERCEL_DEPLOYMENT_ID=""
VERCEL_ENV=""
VERCEL_REGION=""
VERCEL_PROJECT_ID=""


# -----------------------------------------------------------------------------
# Gladia (@ai-sdk/gladia)
# -----------------------------------------------------------------------------
GLADIA_API_KEY=""


# -----------------------------------------------------------------------------
# Google Generative AI (@ai-sdk/google)
# -----------------------------------------------------------------------------
GOOGLE_GENERATIVE_AI_API_KEY=""


# -----------------------------------------------------------------------------
# Google Vertex AI (@ai-sdk/google-vertex)
# -----------------------------------------------------------------------------
# Use GOOGLE_VERTEX_API_KEY for API-key auth. For service-account auth (edge
# runtime), set GOOGLE_CLIENT_EMAIL + GOOGLE_PRIVATE_KEY (and optionally
# GOOGLE_PRIVATE_KEY_ID). GOOGLE_VERTEX_PROJECT and GOOGLE_VERTEX_LOCATION
# identify the target project/region.
GOOGLE_VERTEX_API_KEY=""
GOOGLE_VERTEX_PROJECT=""
GOOGLE_VERTEX_LOCATION=""
GOOGLE_CLIENT_EMAIL=""
GOOGLE_PRIVATE_KEY=""
GOOGLE_PRIVATE_KEY_ID=""


# -----------------------------------------------------------------------------
# Groq (@ai-sdk/groq)
# -----------------------------------------------------------------------------
GROQ_API_KEY=""


# -----------------------------------------------------------------------------
# Hugging Face (@ai-sdk/huggingface)
# -----------------------------------------------------------------------------
HUGGINGFACE_API_KEY=""


# -----------------------------------------------------------------------------
# Hume (@ai-sdk/hume)
# -----------------------------------------------------------------------------
HUME_API_KEY=""


# -----------------------------------------------------------------------------
# KlingAI (@ai-sdk/klingai)
# -----------------------------------------------------------------------------
KLINGAI_ACCESS_KEY=""
KLINGAI_SECRET_KEY=""


# -----------------------------------------------------------------------------
# LMNT (@ai-sdk/lmnt)
# -----------------------------------------------------------------------------
LMNT_API_KEY=""


# -----------------------------------------------------------------------------
# Luma (@ai-sdk/luma)
# -----------------------------------------------------------------------------
LUMA_API_KEY=""


# -----------------------------------------------------------------------------
# Mistral (@ai-sdk/mistral)
# -----------------------------------------------------------------------------
MISTRAL_API_KEY=""


# -----------------------------------------------------------------------------
# Moonshot AI (@ai-sdk/moonshotai)
# -----------------------------------------------------------------------------
MOONSHOT_API_KEY=""


# -----------------------------------------------------------------------------
# OpenAI (@ai-sdk/openai)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=""
# Override the default API base URL (optional).
OPENAI_BASE_URL=""


# -----------------------------------------------------------------------------
# Perplexity (@ai-sdk/perplexity)
# -----------------------------------------------------------------------------
PERPLEXITY_API_KEY=""


# -----------------------------------------------------------------------------
# Prodia (@ai-sdk/prodia)
# -----------------------------------------------------------------------------
PRODIA_TOKEN=""


# -----------------------------------------------------------------------------
# QuiverAI (@ai-sdk/quiverai)
# -----------------------------------------------------------------------------
QUIVERAI_API_KEY=""
# Override the default API base URL (optional).
QUIVERAI_BASE_URL=""


# -----------------------------------------------------------------------------
# Replicate (@ai-sdk/replicate)
# -----------------------------------------------------------------------------
REPLICATE_API_TOKEN=""


# -----------------------------------------------------------------------------
# Rev.ai (@ai-sdk/revai)
# -----------------------------------------------------------------------------
REVAI_API_KEY=""


# -----------------------------------------------------------------------------
# Together AI (@ai-sdk/togetherai)
# -----------------------------------------------------------------------------
# TOGETHER_AI_API_KEY is deprecated; prefer TOGETHER_API_KEY.
TOGETHER_API_KEY=""
TOGETHER_AI_API_KEY=""


# -----------------------------------------------------------------------------
# Vercel v0 (@ai-sdk/vercel)
# -----------------------------------------------------------------------------
VERCEL_API_KEY=""


# -----------------------------------------------------------------------------
