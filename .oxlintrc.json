    "func-names": "off",
    "func-style": "off",
    "grouped-accessor-pairs": "off",
    "guard-for-in": "off",
    "max-classes-per-file": "off",
    "no-alert": "off",
    "no-async-promise-executor": "off",
    "no-bitwise": "off",
    "no-case-declarations": "off",
    "no-constant-condition": "off",
    "no-div-regex": "off",
    "no-duplicate-imports": "off",
    "no-else-return": "off",
    "no-empty": "off",
    "no-empty-function": "off",
    "no-empty-pattern": "off",
    "no-eq-null": "off",
    "no-eval": "off",
