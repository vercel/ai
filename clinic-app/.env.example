NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Shared secret sent by the NFS-e gateway in the `x-webhook-secret` header.
# Must match the value stored in public.nfse_webhook_config.
NFSE_WEBHOOK_SECRET=
# Shared secret sent by the payment gateway (Stripe/Asaas) in the
# `x-webhook-secret` header. Must match public.billing_webhook_config.
BILLING_WEBHOOK_SECRET=
# Base URL for this project's Supabase Edge Functions.
SUPABASE_FUNCTIONS_URL=
# Shared secret used when the Next.js app invokes internal Edge Functions
# (e.g. export-clinic-data). Must match public.internal_service_config
# and the INTERNAL_FUNCTIONS_SECRET env var configured on the Edge Functions.
INTERNAL_FUNCTIONS_SECRET=
# Shared secret sent by your WhatsApp integration layer in the
# `x-webhook-secret` header when calling /api/chat/whatsapp-agent. Must match
# public.whatsapp_webhook_config (also used to authorize the agent's tool
# calls to whatsapp_get_available_slots / whatsapp_book_appointment).
WHATSAPP_AGENT_SECRET=
# AI Gateway model id used by the scheduling agent. Defaults to
# anthropic/claude-sonnet-4.5 — run `curl https://ai-gateway.vercel.sh/v1/models`
# to confirm the latest available id before deploying.
WHATSAPP_AGENT_MODEL=
# Required by the AI SDK Gateway outside of Vercel deployments (Vercel
# deployments authenticate automatically via OIDC).
AI_GATEWAY_API_KEY=
