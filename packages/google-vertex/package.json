{
  "name": "@ai-sdk/google-vertex",
  "version": "5.0.0-beta.26",
  "license": "Apache-2.0",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist/**/*",
    "docs/**/*",
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.test-d.ts",
    "!src/**/__snapshots__",
    "!src/**/__fixtures__",
    "CHANGELOG.md",
    "README.md",
    "edge.d.ts",
    "anthropic/edge.d.ts",
    "anthropic/index.d.ts",
    "maas/edge.d.ts",
    "maas/index.d.ts"
  ],
  "directories": {
    "doc": "./docs"
  },
  "scripts": {
    "build": "pnpm clean && tsup --tsconfig tsconfig.build.json",
    "build:watch": "pnpm clean && tsup --watch",
    "clean": "del-cli dist docs *.tsbuildinfo",
    "prepack": "mkdir -p docs && cp ../../content/providers/01-ai-sdk-providers/16-google-vertex.mdx ./docs/",
    "postpack": "del-cli docs",
    "type-check": "tsc --build",
    "test": "pnpm test:node && pnpm test:edge",
    "test:update": "pnpm test:node -u",
    "test:watch": "vitest --config vitest.node.config.js",
    "test:edge": "vitest --config vitest.edge.config.js --run",
    "test:node": "vitest --config vitest.node.config.js --run"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./edge": {
      "types": "./dist/edge/index.d.mts",
      "import": "./dist/edge/index.mjs",
      "default": "./dist/edge/index.mjs"
    },
    "./anthropic": {
      "types": "./dist/anthropic/index.d.mts",
      "import": "./dist/anthropic/index.mjs",
      "default": "./dist/anthropic/index.mjs"
    },
    "./anthropic/edge": {
      "types": "./dist/anthropic/edge/index.d.mts",
      "import": "./dist/anthropic/edge/index.mjs",
      "default": "./dist/anthropic/edge/index.mjs"
    },
    "./maas": {
      "types": "./dist/maas/index.d.mts",
      "import": "./dist/maas/index.mjs",
      "default": "./dist/maas/index.mjs"
    },
    "./maas/edge": {
      "types": "./dist/maas/edge/index.d.mts",
      "import": "./dist/maas/edge/index.mjs",
      "default": "./dist/maas/edge/index.mjs"
    }
  },
  "dependencies": {
    "@ai-sdk/anthropic": "workspace:*",
    "@ai-sdk/google": "workspace:*",
    "@ai-sdk/openai-compatible": "workspace:*",
    "@ai-sdk/provider": "workspace:*",
    "@ai-sdk/provider-utils": "workspace:*",
    "google-auth-library": "^10.5.0"
  },
  "devDependencies": {
    "@ai-sdk/test-server": "workspace:*",
    "@types/node": "20.17.24",
    "@vercel/ai-tsconfig": "workspace:*",
    "tsup": "^8",
    "typescript": "5.8.3",
    "zod": "3.25.76"
  },
  "peerDependencies": {
    "zod": "^3.25.76 || ^4.1.8"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://ai-sdk.dev/docs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vercel/ai.git"
  },
  "bugs": {
    "url": "https://github.com/vercel/ai/issues"
  },
  "keywords": [
    "ai"
  ]
}
