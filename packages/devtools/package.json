{
  "name": "@ai-sdk/devtools",
  "version": "1.0.0-beta.30",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "devtools": "./bin/cli.js"
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.test-d.ts",
    "!src/**/__snapshots__",
    "!src/**/__fixtures__",
    "bin"
  ],
  "scripts": {
    "dev": "concurrently -k \"pnpm dev:api\" \"pnpm dev:client\"",
    "dev:api": "AI_SDK_DEVTOOLS_DEV=true tsx src/viewer/server.ts",
    "dev:client": "vite",
    "example": "tsx examples/basic/index.ts",
    "start": "node dist/viewer/server.js",
    "build": "pnpm build:client && pnpm build:server",
    "build:client": "vite build",
    "build:server": "tsup --tsconfig tsconfig.build.json",
    "test": "vitest --config vitest.node.config.js --run",
    "test:watch": "vitest --config vitest.node.config.js",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@ai-sdk/provider": "workspace:*",
    "@hono/node-server": "^1.19.14",
    "hono": "^4.12.18"
  },
  "devDependencies": {
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "22.19.19",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "ai": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^0.556.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.8.3",
    "vaul": "^1.1.2",
    "vite": "^6.4.2",
    "vitest": "^4.1.6",
    "zod": "3.25.76"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "homepage": "https://ai-sdk.dev/docs",
  "repository": {
    "type": "git",
    "url": "https://github.com/vercel/ai",
    "directory": "packages/devtools"
  },
  "bugs": {
    "url": "https://github.com/vercel/ai/issues"
  },
  "license": "Apache-2.0",
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "ai"
  ]
}
