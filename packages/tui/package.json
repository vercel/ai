{
  "name": "@ai-sdk/tui",
  "version": "1.0.0-beta.22",
  "type": "module",
  "description": "Run AI SDK agents in a terminal UI.",
  "license": "Apache-2.0",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "source": "./src/index.ts",
  "files": [
    "dist/**/*",
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.test-d.ts",
    "!src/**/__snapshots__",
    "!src/**/__fixtures__",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm clean && tsup --tsconfig tsconfig.build.json",
    "build:watch": "pnpm clean && tsup --watch",
    "clean": "del-cli dist *.tsbuildinfo",
    "type-check": "tsc --build",
    "test": "vitest --config vitest.node.config.js --run",
    "test:update": "vitest --config vitest.node.config.js --run -u",
    "test:watch": "vitest --config vitest.node.config.js"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "ai": "workspace:*"
  },
  "devDependencies": {
    "@ai-sdk/provider": "workspace:*",
    "@types/node": "22.19.19",
    "@vercel/ai-tsconfig": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "5.8.3",
    "vitest": "^4.1.6",
    "zod": "3.25.76"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "homepage": "https://ai-sdk.dev/docs",
  "repository": {
    "type": "git",
    "url": "https://github.com/vercel/ai",
    "directory": "packages/tui"
  },
  "bugs": {
    "url": "https://github.com/vercel/ai/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "chatbot",
    "cli",
    "terminal",
    "tui"
  ]
}
